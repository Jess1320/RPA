# =========================
# RPA_CEXT_PROD_DIARIO
# =========================

# URLs ExplotaDatos / ESSI
URL_HOME=http://appsgasistexpl.essalud.gob.pe/explotaDatos/
FRM_MASIVAS=http://appsgasistexpl.essalud.gob.pe/explotaDatos/servlet/CtrlControl?opt=adm16

# Google Sheets
GSHEET_URL=https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
CREDS_JSON=service-account.example.json
GSHEET_TABS=ESPECIALIDADES,CENACRON

# Credenciales por macroregion. No colocar valores reales en Git.
USER_CENTRO=
PASSWORD_CENTRO=
USER_NORTE=
PASSWORD_NORTE=
USER_SUR=
PASSWORD_SUR=
USER_LIMA_ORIENTE=
PASSWORD_LIMA_ORIENTE=

# Descargas y publicacion
DOWNLOAD_DIRS=/home/cenate/rpa_cext_diario/DIARIAS_TMP
FINAL_PUBLISH_DIR=/mnt/abandonos/BASES_DIARIAS

# Motor
HEADLESS=true
DOWNLOAD_TIMEOUT=180
BETWEEN_CENTERS_DELAY=2
RETRY_PER_CENTER=1
MAX_THREADS=6
MAX_CONCURRENT_DRIVER_STARTS=1

# Diario
DATE_OFFSET_DAYS=0
END_OFFSET_DAYS=2
SPECIAL_RANGE_WEEKDAYS=4
SPECIAL_END_OFFSET_DAYS=3
FORCE_REDOWNLOAD=true
FILE_SUFFIX=PacCitCExt.txt
KEEP_ONLY_CURRENT_TAG=true

# Logs
RUN_NAME=CEXT_PROD_DIARIO
LOGS_DIR=logs
LOG_RETENTION_DAYS=15

# Temporales Chrome
CHROME_TMP_ROOT=/home/cenate/rpa_cext_diario/tmp_chrome
CHROME_TMP_RETENTION_HOURS=12

# PostgreSQL control
PG_HOST=
PG_PORT=5432
PG_DATABASE=
PG_USER=
PG_PASSWORD=

# PostgreSQL origen auxiliar 241
SRC241_HOST=10.0.89.241
SRC241_PORT=5432
SRC241_DATABASE=
SRC241_USER=
SRC241_PASSWORD=

# Identidad del job
RPA_JOB_CODE=CEXT_PROD_DIARIO
RPA_JOB_NAME=RPA Consulta Externa Produccion Diario
RPA_RUN_TYPE=DIARIO
RPA_FAIL_IF_DB_DOWN=true

# Notificacion por correo
MAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=
SMTP_CC=
