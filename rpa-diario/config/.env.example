# ExplotaDatos / ESSI
EXPLOTADATOS_URL=https://example.invalid/explotadatos
EXPLOTADATOS_REPORT_URL=https://example.invalid/explotadatos/reporte-interno

# Credenciales
# No colocar valores reales en Git.
EXPLOTADATOS_USER=
EXPLOTADATOS_PASSWORD=

# Google Sheets
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_TABS=ESPECIALIDADES,CENACRON

# PostgreSQL
POSTGRES_DSN=postgresql://usuario:password@host:5432/rpa_control

# Ejecucion
MAX_WORKERS=6
DOWNLOAD_TIMEOUT_SECONDS=180
HEADLESS=true
FORCE_REDOWNLOAD=true

# Notificaciones
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

