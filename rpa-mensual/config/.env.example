# RPA Mensual CEXT - ejemplo sin secretos

URL_HOME=
FRM_MASIVAS=

GSHEET_URL=
CREDS_JSON=
GSHEET_TABS=ESPECIALIDADES,CENACRON

# Mes: ACTUAL, ANTERIOR, SIGUIENTE, YYYY-MM o lista separada por comas
MES_A_PROCESAR=ACTUAL

CLOSE_MONTH=false
CLOSE_MONTH_PERIOD=

USER_CENTRO=
PASSWORD_CENTRO=
USER_NORTE=
PASSWORD_NORTE=
USER_SUR=
PASSWORD_SUR=
USER_LIMA_ORIENTE=
PASSWORD_LIMA_ORIENTE=

DOWNLOAD_DIRS=
FINAL_PUBLISH_DIR=
FINAL_PUBLISH_MIRRORS=

HEADLESS=true
DOWNLOAD_TIMEOUT=1500
BETWEEN_CENTERS_DELAY=2
RETRY_PER_CENTER=1
MAX_THREADS=6

FORCE_REDOWNLOAD=true
FILE_SUFFIX=PacCitCExt.txt
KEEP_ONLY_CURRENT_TAG=true

RUN_NAME=CEXT_PROD_MENSUAL
LOGS_DIR=logs
LOG_RETENTION_DAYS=14

PG_HOST=
PG_PORT=5432
PG_DATABASE=
PG_USER=
PG_PASSWORD=

SRC241_HOST=
SRC241_PORT=5432
SRC241_DATABASE=
SRC241_USER=
SRC241_PASSWORD=

RPA_JOB_CODE=CEXT_PROD_MENSUAL
RPA_JOB_NAME=RPA Consulta Externa Produccion Mensual
RPA_RUN_TYPE=MENSUAL
RPA_FAIL_IF_DB_DOWN=true

CHROME_PROFILE_BASE_DIR=/opt/rpa/tmp/chrome_profiles
CHROME_PROFILE_MAX_AGE_HOURS=24
HEALTHCHECK_ENABLED=true
HEALTHCHECK_BLOCKING=true
DB_PRECHECK_ENABLED=true
DB_CONNECT_TIMEOUT_SECONDS=5

MAIL_ENABLED=false
